#!/bin/sh

# Date & Time

clock=$(date '+%I')

case "$clock" in
	"00") icon="ЁЯХЫ" ;;
	"01") icon="ЁЯХР" ;;
	"02") icon="ЁЯХС" ;;
	"03") icon="ЁЯХТ" ;;
	"04") icon="ЁЯХУ" ;;
	"05") icon="ЁЯХФ" ;;
	"06") icon="ЁЯХХ" ;;
	"07") icon="ЁЯХЦ" ;;
	"08") icon="ЁЯХЧ" ;;
	"09") icon="ЁЯХШ" ;;
	"10") icon="ЁЯХЩ" ;;
	"11") icon="ЁЯХЪ" ;;
	"12") icon="ЁЯХЫ" ;;
esac

date "+[ЁЯЧУ %b %d|$icon %I:%M%p]"
